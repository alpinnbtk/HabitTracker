<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/habit_navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.project1_weare.view.LoginFragment"
        android:label="LoginFragment" >
        <action
            android:id="@+id/action_dashboard"
            app:destination="@id/dashboardFragment" />
    </fragment>
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.project1_weare.view.DashboardFragment"
        android:label="DashboardFragment" >
        <action
            android:id="@+id/action_dashboardFragment_to_newHabitFragment"
            app:destination="@id/newHabitFragment" />
    </fragment>
    <fragment
        android:id="@+id/newHabitFragment"
        android:name="com.example.project1_weare.view.NewHabitFragment"
        android:label="NewHabitFragment" />
</navigation>